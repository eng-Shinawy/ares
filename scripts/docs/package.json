{
  "name": "@ares/docs",
  "version": "1.0.0",
  "description": "Ares documentation generation pipeline - packs repo context and generates academic chapters via AI",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "generate": "bun run generate.ts",
    "generate:all": "bun run generate.ts --all",
    "generate:ch1": "bun run generate.ts --chapter 1",
    "generate:ch2": "bun run generate.ts --chapter 2",
    "generate:ch3": "bun run generate.ts --chapter 3",
    "generate:ch4": "bun run generate.ts --chapter 4",
    "generate:ch5": "bun run generate.ts --chapter 5",
    "generate:appendix": "bun run generate.ts --chapter appendix",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsgo -b --noEmit --extendedDiagnostics",
    "validate-mermaid": "bun run validate-mermaid.ts",
    "mermaid-compile": "bun run validate-mermaid.ts",
    "mermaid-check": "bun run validate-mermaid.ts",
    "mermaid-iterate": "bun run mermaid-iterate.ts",
    "pdf": "bun run pdf.ts",
    "pdf:count": "bun run pdf.ts --count-only",
    "pdf:clean": "bun run pdf.ts --clean"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "openai": "^4.104.0",
    "ora": "^9.4.1",
    "repomix": "^1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cspell/dict-ar": "^1.1.7",
    "@cspell/eslint-plugin": "^10.0.0",
    "@eslint/js": "^10.0.1",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript/native-preview": "^7.0.0-dev.20260415.1",
    "eslint": "^10.2.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
