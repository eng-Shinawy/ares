# OpenAI-compatible API configuration
CUSTOM_API_ENDPOINT=https://your-custom-endpoint.com/v1
CUSTOM_API_KEY=your-secret-key

# Model configuration
AI_MODEL=gpt-4o

# Token limits - set to your AI model's maximum input context
# GPT-4o: 128000, GPT-4o-mini: 128000, GLM-5.1: 200000, Qwen3.5-397B: 131072
MAX_INPUT_TOKENS=128000

# Maximum tokens for AI response (controls output length per chapter)
MAX_OUTPUT_TOKENS=16384

# Parallel chapter generation - how many chapters to generate concurrently
# Higher = faster but uses more API quota simultaneously
CONCURRENCY=3

# Output directory (relative to scripts/docs/)
OUTPUT_DIR=../../docs

# Repomix packing options
COMPRESS_CONTEXT=true
REMOVE_EMPTY_LINES=true
REMOVE_COMMENTS=false
INCLUDE_GIT_LOGS=false
INCLUDE_GIT_DIFFS=false
