# OpenAI-compatible API configuration
CUSTOM_API_ENDPOINT=https://your-custom-endpoint.com/v1
CUSTOM_API_KEY=your-secret-key

# Model configuration
AI_MODEL=gpt-4o

# Token limits - set to your AI model's maximum input context
# Recommended max: 128000 for fast processing
# GPT-4o: 128000, GPT-4o-mini: 128000, GLM-5.1: 200000, Qwen3.5-397B: 131072
MAX_INPUT_TOKENS=128000

# Maximum tokens for AI response (controls output length per chapter part)
# Higher values allow more detailed output per API call
MAX_OUTPUT_TOKENS=128000

# Parallel chapter generation - how many chapters to generate concurrently
# Higher = faster but uses more API quota simultaneously
CONCURRENCY=3

# Maximum streaming timeout per chapter part (minutes)
GENERATION_TIMEOUT=10

# Split monolithic sections (exceeding MAX_OUTPUT_TOKENS) into sub-sections?
SPLIT_MONOLITHIC_SECTIONS=true

# Character-based split chunk size (used as fallback when section headers are missing)
FALLBACK_SPLIT_CHARS=50000

# Output directory (relative to scripts/docs/)
OUTPUT_DIR=../../docs/generated

# Mermaid & pagination control
INCLUDE_DIAGRAMS=true
MERMAID_THEME=default
MERMAID_FONT_SIZE=11
PAGE_TARGET=200
# INCLUDE_TEST_CASES_MATRIX=true
# INCLUDE_INFRA_MAP=true

# Repomix packing options
COMPRESS_CONTEXT=true
REMOVE_EMPTY_LINES=true
REMOVE_COMMENTS=false
INCLUDE_GIT_LOGS=false
INCLUDE_GIT_DIFFS=false
