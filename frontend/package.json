{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "bash ../scripts/dev.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --concurrency=auto --cache",
    "lint:fix": "eslint . --fix --concurrency=auto --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tsc": "tsc --extendedDiagnostics --noEmit",
    "tsgo": "tsgo -b --noEmit --extendedDiagnostics",
    "codescene": "bash health/codescene/codescene.sh",
    "sonar-scan": "bash health/sonar/run.sh",
    "sonar-result": "bun run health/sonar/result_only.ts",
    "sonar-full": "bun run health/sonar/result_with_duplications.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.15",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^9.0.4",
    "@mui/x-date-pickers": "^9.0.4",
    "@types/bun": "^1.3.13",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.12.43",
    "lucide-react": "^1.14.0",
    "next": "16.2.5",
    "next-auth": "^4.24.14",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.75.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cspell/dict-ar": "^1.1.7",
    "@cspell/eslint-plugin": "^10.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260507.1",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "16.2.5",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
