# Backend environment configuration
# Copy this file to .env and fill in your values.
#
# ASP.NET Core maps __ as the section separator:
#   ConnectionStrings__DefaultConnection  →  ConnectionStrings:DefaultConnection
#   Jwt__SecretKey                        →  Jwt:SecretKey
#
# Do NOT quote values — the shell loader handles special characters correctly.

# ── Database ──────────────────────────────────────────────────────────────────
# Inside devcontainer the SQL Server host is "mssql" (docker-compose service name).
# Outside devcontainer use "localhost".
ConnectionStrings__DefaultConnection=Server=mssql,1433;Database=ares;User=sa;Password=YourPassword123!;TrustServerCertificate=True;Encrypt=false

# ── JWT ───────────────────────────────────────────────────────────────────────
Jwt__SecretKey=YourSuperSecretKeyThatIsAtLeast32CharactersLong!
Jwt__Issuer=AresCarRentalApi
Jwt__Audience=AresCarRentalClient
Jwt__ExpirationMinutes=60
Jwt__ExtendedExpirationDays=400

# ── CORS ──────────────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:3001

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
