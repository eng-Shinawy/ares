{
  "js/ts.tsdk.path": "frontend/node_modules/typescript/lib",
  // Show prompt when workspace TS is detected
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.autoClosingTags.enabled": false,
  "kiroAgent.configureMCP": "Disabled",
  "sqltools.connections": [
    {
      "connectionTimeout": 15,
      "mssqlOptions": {
        "appName": "SQLTools",
        "useUTC": true,
        "encrypt": true,
        "trustServerCertificate": true
      },
      "ssh": "Disabled",
      "previewLimit": 50,
      "server": "localhost",
      "port": 1433,
      "driver": "MSSQL",
      "name": "ares",
      "username": "sa",
      "password": "YourPassword123!"
    }
  ],
  "files.associations": {
    "*.log": "log",
    "*.log.*": "log"
  },
  "[log]": {
    "editor.largeFileOptimizations": false
  },
  "logFileHighlighter.enableTailMode": true,
  "logFileHighlighter.enableProgressIndicator": true,
  "chat.mcp.discovery.enabled": {},
  "chat.mcp.access": "all"
}
